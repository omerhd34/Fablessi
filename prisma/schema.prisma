generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Ürün kategori grubu (ör. Oturma Grupları, Köşe Grupları)
model ProductCategoryGroup {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  nameEn      String?
  coverImage  String?
  sortOrder   Int       @default(0)
  isPublished Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products Product[]

  @@index([isPublished, sortOrder])
  @@map("product_category_groups")
}

/// Katalog ürünü
model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  nameEn        String?
  description   String?  @db.Text
  descriptionEn String?  @db.Text
  /// Serbest metin ölçü özeti (ör. "240 x 90 x 75 cm")
  dimensions      String?
  /// Parça bazlı ölçü ve fiyat tablosu: [{ name?, nameEn?, widthCm, depthCm, heightCm, amount?, quantity? }]
  dimensionItems  Json?
  widthCm         Decimal? @db.Decimal(8, 2)
  heightCm        Decimal? @db.Decimal(8, 2)
  depthCm         Decimal? @db.Decimal(8, 2)
  sortOrder      Int      @default(0)
  isPublished    Boolean  @default(true)
  /// Anasayfa vitrininde gösterilecek ürünler
  isFeatured     Boolean  @default(false)
  featuredOrder  Int      @default(0)
  sku            String?  @unique
  categoryGroupId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  categoryGroup ProductCategoryGroup? @relation(fields: [categoryGroupId], references: [id], onDelete: SetNull)
  images        Image[]

  @@index([categoryGroupId])
  @@index([isPublished, sortOrder])
  @@index([isFeatured, featuredOrder])
  @@map("products")
}

/// Ürün görseli (galeri)
model Image {
  id        String   @id @default(cuid())
  productId String
  url       String   @db.VarChar(2048)
  alt       String?
  altEn     String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("images")
}

/// Site içerik blokları (hakkımızda, SSS metinleri, yasal sayfalar vb.)
model ContentBlock {
  key       String   @id
  contentTr Json
  contentEn Json
  updatedAt DateTime @updatedAt

  @@map("content_blocks")
}

/// SSS kategorisi
model FaqCategory {
  id             String    @id @default(cuid())
  slug           String    @unique
  titleTr        String
  titleEn        String?
  sortOrder      Int       @default(0)
  initialVisible Int       @default(4)
  items          FaqItem[]

  @@index([sortOrder])
  @@map("faq_categories")
}

/// SSS sorusu
model FaqItem {
  id         String      @id @default(cuid())
  categoryId String
  questionTr String      @db.Text
  questionEn String?     @db.Text
  answerTr   String      @db.Text
  answerEn   String?     @db.Text
  sortOrder  Int         @default(0)
  category   FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId, sortOrder])
  @@map("faq_items")
}
